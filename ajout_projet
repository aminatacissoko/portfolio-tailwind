<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Mes Projets - Aminata</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-950 text-white font-sans">

  <!-- HEADER -->
  <header class="bg-gray-900 shadow-lg sticky top-0 z-50">
    <nav class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
      <h1 class="text-2xl font-bold text-violet-400">Aminata.dev</h1>
      <ul class="flex gap-6 text-sm font-medium">
        <li><a href="index.html" class="hover:text-violet-400 transition">Accueil</a></li>
        <li><a href="projets.html" class="text-violet-400 font-bold">Projets</a></li>
        <li><a href="ajouter-projet.html" class="hover:text-violet-400 transition">Ajouter un projet</a></li>
      </ul>
    </nav>
  </header>

  <!-- PROJETS -->
  <section class="py-20 max-w-6xl mx-auto px-6">
    <div class="flex justify-between items-center mb-12">
      <h2 class="text-4xl font-bold text-violet-400">Mes Projets</h2>
      <a href="ajouter-projet.html" class="bg-violet-500 hover:bg-violet-600 text-white px-6 py-2 rounded-full font-semibold transition">
        + Ajouter un projet
      </a>
    </div>

    <!-- Liste des projets -->
    <div id="liste-projets" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Les projets seront affichés ici par JavaScript -->
    </div>

    <!-- Message si aucun projet -->
    <div id="aucun-projet" class="text-center text-gray-400 py-20 hidden">
      <p class="text-2xl mb-4">😕 Aucun projet pour l'instant</p>
      <a href="ajouter-projet.html" class="bg-violet-500 hover:bg-violet-600 text-white px-6 py-2 rounded-full font-semibold transition">
        Ajouter mon premier projet
      </a>
    </div>

  </section>

  <!-- FOOTER -->
  <footer class="bg-gray-900 text-center text-gray-400 py-6">
    <p>© 2024 Aminata Cissoko — Tous droits réservés</p>
  </footer>

  <script src="js/projets.js"></script>
</body>
</html>